# Required: Get your free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Required: Authentication. Sign up at https://clerk.com and create an app, then copy these from the API Keys page.
CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
CLERK_SECRET_KEY=sk_test_your-secret-key-here

# Database location. SQLite by default — works out of the box.
# To switch to Postgres later: DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./app.db

# Optional: which Gemini model to use. Default is gemini-2.5-flash-lite (free tier friendly).
# Other options: gemini-2.5-flash (more capable, smaller free quota), gemini-2.5-pro (paid only).
GEMINI_MODEL=gemini-2.5-flash-lite
